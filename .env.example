# ========================================
# SportsPulse — Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs
# ========================================

# ---- App ----
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="SportsPulse"

# ---- Base de données (Postgres uniquement, pas de SQLite local) ----
# Workflow dev recommandé : `railway run npm run dev` (injecte DATABASE_URL prod auto)
# Workflow alternatif : copier la valeur depuis Railway dashboard → ici
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Push schéma au boot — TRUE uniquement pour le 1er deploy d'un projet vide.
# Ensuite mettre à FALSE en variable Railway pour éviter tout wipe involontaire.
# Les changements de schéma passent alors par des migrations explicites.
PUSH_SCHEMA=false

# ---- Payload CMS ----
# Min. 32 caractères — générer : openssl rand -base64 32
PAYLOAD_SECRET=your_payload_secret_min_32_chars

# ---- Auth ----
NEXTAUTH_SECRET=your_nextauth_secret_min_32_chars
NEXTAUTH_URL=http://localhost:3000

# ---- Cache + rate limiting ----
# DEV : fallback mémoire si REDIS_URL absent
# PROD : Railway Redis plugin injecte REDIS_URL
REDIS_URL=redis://localhost:6379

# ---- Chatbot LLM Claude (obligatoire en prod) ----
ANTHROPIC_API_KEY=sk-ant-...

# ---- Emails transactionnels (Resend) ----
RESEND_API_KEY=re_your_key_here
EMAIL_FROM=noreply@sportspulse.fr
NEWSLETTER_FROM_EMAIL=newsletter@sportspulse.fr

# ---- Google (optionnel — fallback global, par-club via CMS) ----
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GA4_MEASUREMENT_ID=

# ---- Observability (Sentry) ----
# Activer en prod uniquement. Laisser vide en dev.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ---- Dev local — forcer un club par domaine ----
# Sans Redis, le résolveur tenant a besoin d'un domaine fixe
DEV_CLUB_DOMAIN=clubvoile-pau.fr

# ---- CI/CD ----
# SKIP_ENV_VALIDATION=true
